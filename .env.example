# Neon / Vercel Postgres / локальный Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# Пароль для входа в /admin
ADMIN_PASSWORD="change-me"

# Случайная длинная строка (для подписи cookie сессии)
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# Vercel Blob (для загрузки фото товаров)
# На Vercel: подключите Blob Store через Dashboard → Storage → Create → Blob
# Токен добавится автоматически. Локально скопируйте его из Vercel.
BLOB_READ_WRITE_TOKEN=""
