generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  sku            String   @unique
  weightGrams    Int
  reviewCount    Int      @default(0)
  rating         Float
  reviewsSummary String?
  category       String?
  attributes     Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
}
